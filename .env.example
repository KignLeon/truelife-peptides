# True Life Peptides — Environment Variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore — NEVER commit credentials to git.

# ─────────────────────────────────────────────────────────
# WOOCOMMERCE (Required for live product data)
# ─────────────────────────────────────────────────────────
# Your WooCommerce store URL (no trailing slash)
WC_URL=https://your-woocommerce-site.com

# WooCommerce REST API credentials
# Generate at: WooCommerce > Settings > Advanced > REST API
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────
# CORS (Optional — defaults to * if not set)
# ─────────────────────────────────────────────────────────
# Set this to your Vercel deployment URL to restrict API access
FRONTEND_URL=https://truelifepeptides.com

# ─────────────────────────────────────────────────────────
# SUPABASE (Optional — used for auth gate)
# ─────────────────────────────────────────────────────────
# Only needed if using Supabase auth. The anon key is public-safe
# but ensure Row Level Security (RLS) is enabled in your Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────
# CONTACT FORM (Required for contact form to send emails)
# ─────────────────────────────────────────────────────────
# Get a free access key at: https://web3forms.com
# Add this key to contact/index.html: <input type="hidden" name="access_key" value="YOUR_KEY">
WEB3FORMS_ACCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─────────────────────────────────────────────────────────
# SETUP CHECKLIST
# ─────────────────────────────────────────────────────────
# 1. Set WC_URL, WC_CONSUMER_KEY, WC_CONSUMER_SECRET in Vercel dashboard
#    → Vercel > Project > Settings > Environment Variables
# 2. Get Web3Forms key at web3forms.com and update contact/index.html
# 3. Verify WooCommerce REST API is enabled:
#    → WooCommerce > Settings > Advanced > REST API
# 4. Ensure WooCommerce "Consumer Key" has Read permission
# 5. Deploy: git push (Vercel auto-deploys from main branch)
